{
  "version": 2,
  "builds": [
    {
      "src": "admin/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/webhook",
      "dest": "server.js"
    },
    {
      "src": "/health",
      "dest": "server.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "admin/$1"
    },
    {
      "src": "/admin",
      "dest": "admin/"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}